# EUR/USD Morning Brief Agent – Umgebungsvariablen
# Datei: .env  ← NICHT in Git committen!

# ── Telegram Bot ────────────────────────────────────────────
# 1. @BotFather auf Telegram → /newbot
# 2. Token eintragen:
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Deine Chat-ID ermitteln:
#   → @userinfobot schreiben  ODER
#   → https://api.telegram.org/bot<TOKEN>/getUpdates aufrufen
#     und message.chat.id ablesen
TELEGRAM_CHAT_ID=987654321

# ── FRED API Key ────────────────────────────────────────────
# Kostenlos: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=abcdef1234567890abcdef1234567890
